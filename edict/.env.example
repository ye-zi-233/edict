# ⚔️ Edict 三省六部 — Docker 部署配置
# 复制为 .env 并根据环境修改：cp .env.example .env

# ── 容器运行用户 ──
# 设为与 OpenClaw 目录相同的 UID/GID
# NAS 用户请按需修改（可通过 id 命令或 NAS 管理界面查看）
PUID=1000
PGID=1000

# ── OpenClaw 集成 ──
# 宿主机上 OpenClaw 主目录路径（包含 agents/、openclaw.json 等）
OPENCLAW_HOME=~/.openclaw
# Gateway 地址（容器内访问宿主机用 host.docker.internal）
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
# Gateway 认证 Token（无认证则留空）
OPENCLAW_GATEWAY_TOKEN=
# OpenClaw CLI 路径
OPENCLAW_BIN=openclaw

# ── Postgres ──
POSTGRES_DB=edict
POSTGRES_USER=edict
POSTGRES_PASSWORD=edict_secret_change_me
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Backend ──
BACKEND_PORT=8000
DEBUG=false

# ── Frontend ──
FRONTEND_PORT=3000

# ── 数据同步 ──
# 从 OpenClaw 运行时同步数据的间隔（秒）
SYNC_INTERVAL=15

# ── 调度参数 ──
STALL_THRESHOLD_SEC=180
MAX_DISPATCH_RETRY=3
DISPATCH_TIMEOUT_SEC=300

# ── 飞书通知 ──
FEISHU_DELIVER=true
FEISHU_CHANNEL=feishu
