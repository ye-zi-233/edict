# ⚔️ Edict 三省六部 — Docker 部署配置
# 复制为 .env 并根据环境修改：cp .env.example .env

# ── 容器运行用户 ──
# 设为宿主机上运行容器的 UID/GID（id 命令查看）
PUID=1000
PGID=10

# ── 路径配置 ──
# 数据根目录（绝对路径），其下自动创建三个子目录：
#   - postgres/   PostgreSQL 数据
#   - redis/      Redis 数据
#   - edict/      应用运行时数据
# 例如：/volume2/Docker/cat-kingdom/data
EDICT_ROOT=/volume2/Docker/cat-kindom/data

# OpenClaw 主目录绝对路径（包含 agents/、openclaw.json 等）
OPENCLAW_HOME=/volume2/Docker/open-claw/data

# Gateway 地址（容器内访问宿主机用 host.docker.internal）
OPENCLAW_GATEWAY_URL=https://ai.yezi-xhw.cn:10086
# Gateway 认证 Token（无认证则留空）
OPENCLAW_GATEWAY_TOKEN=
# OpenClaw CLI 路径
OPENCLAW_BIN=openclaw

# ── Postgres ──
POSTGRES_DB=edict
POSTGRES_USER=edict
# ⚠️  必须修改！默认值是明文占位，任何人都能猜到
POSTGRES_PASSWORD=edict_secret_change_me
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── 镜像（通常无需修改）──
# 镜像由 GitHub Actions 自动发布到 Docker Hub（ye-zi-233/edict-*）
# EDICT_IMAGE_TAG=cat-kingdom

# ── Backend ──
BACKEND_PORT=8000
DEBUG=false

# ── Frontend ──
FRONTEND_PORT=3000

# ── 数据同步 ──
# 从 OpenClaw 运行时同步数据的间隔（秒）
SYNC_INTERVAL=15

# ── 调度参数 ──
STALL_THRESHOLD_SEC=180
MAX_DISPATCH_RETRY=3
DISPATCH_TIMEOUT_SEC=300

# ── 飞书通知 ──
FEISHU_DELIVER=true
FEISHU_CHANNEL=feishu
