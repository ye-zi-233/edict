# ⚔️ Edict 三省六部 — Docker 部署配置
# 复制为 .env 并根据环境修改：cp .env.example .env

# ── 容器运行用户 ──
# 设为宿主机上运行容器的 UID/GID（id 命令查看）
PUID=1000
PGID=1000

# ── 路径配置 ──
# 项目根目录（仓库根目录绝对路径），同时控制：
#   - agents/、scripts/ 的代码挂载
#   - data/postgres、data/redis、data/edict 的数据挂载
# 必须设为宿主机绝对路径，例如：/home/user/cat 或 /volume1/docker/edict
EDICT_ROOT=/path/to/your/project

# OpenClaw 主目录绝对路径（包含 agents/、openclaw.json 等）
OPENCLAW_HOME=/path/to/your/.openclaw

# Gateway 地址（容器内访问宿主机用 host.docker.internal）
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
# Gateway 认证 Token（无认证则留空）
OPENCLAW_GATEWAY_TOKEN=
# OpenClaw CLI 路径
OPENCLAW_BIN=openclaw

# ── Postgres ──
POSTGRES_DB=edict
POSTGRES_USER=edict
POSTGRES_PASSWORD=edict_secret_change_me
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Backend ──
BACKEND_PORT=8000
DEBUG=false

# ── Frontend ──
FRONTEND_PORT=3000

# ── 数据同步 ──
# 从 OpenClaw 运行时同步数据的间隔（秒）
SYNC_INTERVAL=15

# ── 调度参数 ──
STALL_THRESHOLD_SEC=180
MAX_DISPATCH_RETRY=3
DISPATCH_TIMEOUT_SEC=300

# ── 飞书通知 ──
FEISHU_DELIVER=true
FEISHU_CHANNEL=feishu
