# ⚔️ 三省六部 · Docker 部署配置
# 复制为 .env 并根据环境修改：cp .env.example .env

# 容器运行用户（设为与 OpenClaw 目录相同的 UID/GID，NAS 用户请按需修改）
PUID=1000
PGID=1000

# OpenClaw 主目录（宿主机路径，包含 agents/、openclaw.json 等）
OPENCLAW_HOME=~/.openclaw

# OpenClaw Gateway 地址（容器内访问宿主机用 host.docker.internal）
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789

# OpenClaw Gateway 认证 Token（无认证则留空）
OPENCLAW_GATEWAY_TOKEN=

# 看板端口
DASHBOARD_PORT=7891

# 数据刷新间隔（秒）
SYNC_INTERVAL=15
